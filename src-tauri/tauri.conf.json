{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MicroDeck",
  "version": "0.1.0",
  "identifier": "app.microdeck.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MicroDeck",
        "width": 1180,
        "height": 780,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "center": true
      },
      {
        "label": "controller",
        "title": "MicroDeck Controller",
        "url": "index.html?view=controller",
        "width": 470,
        "height": 680,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"]
  }
}
